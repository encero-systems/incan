[package]
name = "ra_ap_proc_macro_api"
version = "0.0.325"
repository.workspace = true
description = "RPC Api for the `proc-macro-srv` crate of rust-analyzer."

authors.workspace = true
edition.workspace = true
license.workspace = true
rust-version.workspace = true

[lib]
doctest = false

[dependencies]
serde.workspace = true
serde_derive.workspace = true
serde_json = { workspace = true, features = ["unbounded_depth"] }
tracing.workspace = true
rustc-hash.workspace = true
indexmap.workspace = true

# local deps
paths = { workspace = true, features = ["serde1"] }
tt.workspace = true
stdx.workspace = true
proc-macro-srv = {workspace = true, optional = true}
# span = {workspace = true, default-features = false} does not work
span = { path = "../span", version = "=0.0.325", default-features = false, package = "ra_ap_span"}

intern.workspace = true
postcard.workspace = true
semver.workspace = true
rayon.workspace = true

[features]
sysroot-abi = ["proc-macro-srv", "proc-macro-srv/sysroot-abi"]
default = []
in-rust-tree = []

[lints]
workspace = true
