impl<T: Clone, Source: Iterator<T> + Clone> Iterator<Vec<T>>
for BatchIterator<T, Source> {
    fn __next__(&mut self) -> Option<Vec<T>> {
        let _ = "\n        Build and return the next non-empty batch.\n        ";
        if self.size <= 0 {
            raise_value_error("iterator batch size must be greater than zero".into());
