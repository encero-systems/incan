fn squares(xs: Vec<i64>) -> Vec<i64> {
    return (xs).iter().copied().map(|x| x * x).collect::<Vec<_>>();
}
fn positive_squares(xs: Vec<i64>) -> Vec<i64> {
    return (xs)
        .iter()
        .filter_map(|x| {
            let x = *x;
            if x > 0 { Some(x * x) } else { None }
        })
        .collect::<Vec<_>>();
}
fn index_by_value(xs: Vec<i64>) -> std::collections::HashMap<i64, i64> {
    return xs
        .iter()
        .filter_map(|x| {
            let x = *x;
            if x > 0 { Some((x, x * x)) } else { None }
        })
        .collect::<std::collections::HashMap<_, _>>();
}
