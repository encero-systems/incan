fn main() {
    std::panic::set_hook(
        std::boxed::Box::new(|panic_info| {
            if let Some(message) = panic_info.payload().downcast_ref::<&str>() {
                eprintln!("{message}");
            } else if let Some(message) = panic_info.payload().downcast_ref::<String>() {
                eprintln!("{message}");
            } else {
                eprintln!("generated program panicked");
            }
        }),
    );
    let dog: Dog = Dog { name: "Buddy".to_string() };
    let _ = println!(
        "{}", { let __parts : [& str; 2usize] = ["Dog name: ", ""]; let __args : Vec <
        String > = vec![format!("{}", dog.name)]; incan_stdlib::strings::fstring(&
        __parts, & __args) }
    );
    let rect: Rectangle = Rectangle {
        width: 5.0,
        height: 3.0,
    };
    let rect_area: f64 = rect.area();
    let rect_perimeter: f64 = rect.perimeter();
    let _ = println!(
        "{}", { let __parts : [& str; 3usize] = ["Rectangle area: ", ", perimeter: ",
        ""]; let __args : Vec < String > = vec![format!("{}", rect_area), format!("{}",
        rect_perimeter)]; incan_stdlib::strings::fstring(& __parts, & __args) }
    );
    let circle: Circle = Circle { radius: 2.5 };
    let circle_drawing: String = circle.draw();
    let _ = println!("{}", circle_drawing);
    let square: Square = Square { side: 4.0 };
    let square_area: f64 = square.area();
    let square_drawing: String = square.draw();
    let _ = println!(
        "{}", { let __parts : [& str; 2usize] = ["Square area: ", ""]; let __args : Vec <
        String > = vec![format!("{}", square_area)]; incan_stdlib::strings::fstring(&
        __parts, & __args) }
    );
    let _ = println!("{}", square_drawing);
    let mut carton: Carton = Carton {
        width: 2.0,
        height: 3.0,
        depth: 4.0,
    };
    let original_volume: f64 = carton.volume();
    let _ = println!(
        "{}", { let __parts : [& str; 2usize] = ["Original volume: ", ""]; let __args :
        Vec < String > = vec![format!("{}", original_volume)];
        incan_stdlib::strings::fstring(& __parts, & __args) }
    );
    let _ = carton.resize(2.0);
    let new_volume: f64 = carton.volume();
    let _ = println!(
        "{}", { let __parts : [& str; 2usize] = ["New volume: ", ""]; let __args : Vec <
        String > = vec![format!("{}", new_volume)]; incan_stdlib::strings::fstring(&
        __parts, & __args) }
    );
    let doc: Document = Document {
        title: "README".to_string(),
        content: "This is the content".to_string(),
    };
    let doc_str: String = doc.to_string();
    let doc_serial: String = doc.serialize();
    let _ = println!("{}", doc_str);
    let _ = println!("{}", doc_serial);
    let _ = draw_shape(circle);
    let _ = draw_shape(square.clone());
    let area1: f64 = calculate_area(rect);
    let area2: f64 = calculate_area(square);
    let _ = println!(
        "{}", { let __parts : [& str; 3usize] = ["Areas: ", ", ", ""]; let __args : Vec <
        String > = vec![format!("{}", area1), format!("{}", area2)];
