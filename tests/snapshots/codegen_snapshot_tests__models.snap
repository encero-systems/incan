fn create_coordinate(lat: f64, lon: f64) -> Coordinate {
    return Coordinate {
        latitude: lat,
        longitude: lon,
    };
}
#[allow(dead_code)]
fn distance_from_origin(coord: Coordinate) -> f64 {
    let lat_sq = coord.latitude * coord.latitude;
    let lon_sq = coord.longitude * coord.longitude;
    return lat_sq + lon_sq.powf(0.5f64);
}
fn main() {
    std::panic::set_hook(
        std::boxed::Box::new(|panic_info| {
            if let Some(message) = panic_info.payload().downcast_ref::<&str>() {
                eprintln!("{message}");
            } else if let Some(message) = panic_info.payload().downcast_ref::<String>() {
                eprintln!("{message}");
            } else {
                eprintln!("generated program panicked");
            }
        }),
    );
    let user = User {
        name: "Alice".to_string(),
        age: 30,
        email: "alice@example.com".to_string(),
    };
    println!(
