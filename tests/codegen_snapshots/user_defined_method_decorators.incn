# RFC 036: user-defined method decorators

class Box:
    value: int

    @as_int
    def label(self, value: int) -> str:
        return "value"

def parse(box: &Box, value: int) -> int:
    return value

def as_int(func: (&Box, int) -> str) -> (&Box, int) -> int:
    return parse

def run(box: Box) -> int:
    return box.label(1)

def main() -> None:
    box = Box(value=1)
    result = run(box)
