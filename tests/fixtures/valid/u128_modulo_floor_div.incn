def low_byte(value: u128) -> u8:
    return (value % 256).wrapping_resize()


def high_byte(value: u128) -> u8:
    return ((value // 256) % 256).wrapping_resize()


def main() -> None:
    value: u128 = 258
    assert low_byte(value) == 2
    assert high_byte(value) == 1
    println("u128 modulo ok")
