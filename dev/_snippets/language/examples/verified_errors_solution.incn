def safe_div(a: float, b: float) -> Result[float, str]:
    if b == 0.0:
        return Err("division by zero")
    return Ok(a / b)


def first(items: list[str]) -> Option[str]:
    if len(items) == 0:
        return None
    return Some(items[0])


def normalize_name(name: str) -> Result[str, str]:
    cleaned = name.strip()
    if len(cleaned) == 0:
        return Err("name must not be empty")
    return Ok(cleaned.lower())


def greeting_for(name: str) -> Result[str, str]:
    cleaned = normalize_name(name)?
    return Ok(f"hello, {cleaned}")


def main() -> None:
    match first(["a", "b"]):
        case Some(value): println(f"first={value}")
        case None: println("empty")

    match greeting_for(" Ada "):
        case Ok(greeting): println(greeting)
        case Err(error): println(f"error: {error}")

    match safe_div(10.0, 2.0):
        case Ok(value): println(f"10 / 2 = {value}")
        case Err(error): println(f"error: {error}")
